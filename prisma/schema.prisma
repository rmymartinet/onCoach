// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  emailVerified    Boolean          @default(false)
  name             String
  image            String?
  goal             String?
  level            String?
  frequencyPerWeek Int?
  sessionDuration  Int?
  equipment        Json?
  splitPreference  String?
  heightCm         Int?
  weightKg         Float?
  experienceYears  Float?
  trainingLocation String?
  preferredStyles  Json?
  favoriteExercises Json?
  avoidedExercises Json?
  priorityMuscles  Json?
  limitations      Json?
  jobActivityLevel String?
  preferredTrainingTimes Json?
  availableDays    Json?
  onboardingCompletedAt DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  accounts         Account[]
  workouts         Workout[]
  recommendations  Recommendation[]
  coachThreads     CoachThread[]
  planThreads      PlanThread[]
  noteImports      NoteImport[]
  readinessChecks  ReadinessCheck[]
  trainingPlans    TrainingPlan[]
  trainingDayCompletions TrainingDayCompletion[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Workout {
  id             String            @id @default(cuid())
  userId         String
  title          String?
  rawText        String
  cleanedSummary String?
  sessionType    String?
  fatigueNote    String?
  performedAt    DateTime?
  parsingStatus  WorkoutParsingStatus @default(DRAFT)
  parseConfidence Float?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises      WorkoutExercise[]
  recommendations Recommendation[] @relation("RecommendationBaseWorkout")
  matchedCandidates NoteWorkoutCandidate[]

  @@index([userId, createdAt])
}

model WorkoutExercise {
  id             String   @id @default(cuid())
  workoutId      String
  rawLine        String?
  exerciseName   String
  normalizedName String?
  sets           Int?
  reps           Int?
  repMin         Int?
  repMax         Int?
  weight         Float?
  unit           String?
  restSeconds    Int?
  notes          String?
  confidence     Float?
  order          Int
  workout        Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId, order])
}

model Recommendation {
  id               String    @id @default(cuid())
  userId           String
  basedOnWorkoutId String?
  title            String
  goal             String?
  status           RecommendationStatus @default(DRAFT)
  explanation      String?
  coachSummary     String?
  estimatedDurationMinutes Int?
  workoutJson      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  basedOnWorkout   Workout?  @relation("RecommendationBaseWorkout", fields: [basedOnWorkoutId], references: [id], onDelete: SetNull)
  exercises        RecommendationExercise[]
  thread           CoachThread?

  @@index([userId, createdAt])
  @@index([basedOnWorkoutId])
}

model RecommendationExercise {
  id                String   @id @default(cuid())
  recommendationId  String
  order             Int
  name              String
  normalizedName    String?
  sets              Int
  repMin            Int
  repMax            Int
  restSeconds       Int
  targetRpe         Float?
  rir               Float?
  notes             String?
  warmup            Boolean  @default(false)
  exerciseType      String?
  muscleGroups      Json?
  equipment         Json?
  substitutions     Json?
  recommendation    Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId, order])
}

model CoachThread {
  id               String   @id @default(cuid())
  userId           String
  recommendationId String?  @unique
  title            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  messages         CoachMessage[]

  @@index([userId, updatedAt])
}

model CoachMessage {
  id             String   @id @default(cuid())
  threadId       String
  role           CoachMessageRole
  content        String
  actionType     CoachActionType @default(NONE)
  actionPayload  Json?
  createdAt      DateTime @default(now())
  thread         CoachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model NoteImport {
  id             String              @id @default(cuid())
  userId         String
  source         NoteImportSource    @default(APPLE_NOTES_SHARE)
  rawText        String
  normalizedText String?
  contentHash    String
  status         NoteImportStatus    @default(RECEIVED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates     NoteWorkoutCandidate[]

  @@index([userId, createdAt])
  @@index([userId, contentHash])
}

model NoteWorkoutCandidate {
  id               String                    @id @default(cuid())
  noteImportId     String
  title            String?
  rawExcerpt       String
  performedAt      DateTime?
  confidence       Float?
  isMostRecent     Boolean                   @default(false)
  dedupeStatus     NoteCandidateDedupeStatus @default(PENDING)
  dedupeReason     String?
  fingerprint      String?
  parsingStatus    WorkoutParsingStatus      @default(DRAFT)
  matchedWorkoutId String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  noteImport       NoteImport                @relation(fields: [noteImportId], references: [id], onDelete: Cascade)
  matchedWorkout   Workout?                  @relation(fields: [matchedWorkoutId], references: [id], onDelete: SetNull)

  @@index([noteImportId, createdAt])
  @@index([matchedWorkoutId])
}

model ReadinessCheck {
  id                   String   @id @default(cuid())
  userId               String
  energy               Int?
  sleepQuality         Int?
  stress               Int?
  painLevel            Int?
  timeAvailableMinutes Int?
  focusToday           String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model TrainingPlan {
  id               String              @id @default(cuid())
  userId           String
  title            String
  goal             String?
  level            String?
  summary          String?
  split            String?
  status           TrainingPlanStatus  @default(DRAFT)
  progressionNotes Json?
  source           TrainingPlanSource  @default(AI_GENERATED)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks            TrainingWeek[]
  threads          PlanThread[]
  completions      TrainingDayCompletion[]

  @@index([userId, createdAt])
}

model TrainingWeek {
  id         String        @id @default(cuid())
  planId     String
  weekNumber Int
  title      String
  summary    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  plan       TrainingPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  days       TrainingDay[]

  @@index([planId, weekNumber])
}

model TrainingDay {
  id                       String               @id @default(cuid())
  weekId                   String
  order                    Int
  dayLabel                 String
  title                    String
  summary                  String?
  estimatedDurationMinutes Int?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  week                     TrainingWeek         @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises                TrainingDayExercise[]
  threads                  PlanThread[]
  completion               TrainingDayCompletion?

  @@index([weekId, order])
}

model TrainingDayExercise {
  id             String      @id @default(cuid())
  dayId          String
  order          Int
  name           String
  normalizedName String?
  sets           Int
  repMin         Int
  repMax         Int
  restSeconds    Int
  targetRpe      Float?
  rir            Float?
  notes          String?
  warmup         Boolean     @default(false)
  exerciseType   String?
  muscleGroups   Json?
  equipment      Json?
  substitutions  Json?
  day            TrainingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  completion     TrainingDayExerciseCompletion?

  @@index([dayId, order])
}

model TrainingDayCompletion {
  id          String                @id @default(cuid())
  userId      String
  planId      String
  dayId       String                @unique
  status      DayExecutionStatus    @default(PLANNED)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        TrainingPlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  day         TrainingDay           @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercises   TrainingDayExerciseCompletion[]

  @@index([userId, updatedAt])
  @@index([planId, updatedAt])
}

model TrainingDayExerciseCompletion {
  id                 String                  @id @default(cuid())
  completionId       String
  plannedExerciseId  String                  @unique
  order              Int
  name               String
  status             ExerciseExecutionStatus @default(PLANNED)
  completedSets      Int?
  completedRepMin    Int?
  completedRepMax    Int?
  completedWeight    Float?
  completedUnit      String?
  completedRestSeconds Int?
  notes              String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  completion         TrainingDayCompletion   @relation(fields: [completionId], references: [id], onDelete: Cascade)
  plannedExercise    TrainingDayExercise     @relation(fields: [plannedExerciseId], references: [id], onDelete: Cascade)

  @@index([completionId, order])
}

model PlanThread {
  id        String          @id @default(cuid())
  userId    String
  planId    String?
  dayId     String?
  scope     PlanThreadScope @default(PLAN)
  title     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      TrainingPlan?   @relation(fields: [planId], references: [id], onDelete: Cascade)
  day       TrainingDay?    @relation(fields: [dayId], references: [id], onDelete: Cascade)
  messages  PlanMessage[]

  @@index([userId, updatedAt])
  @@index([planId])
  @@index([dayId])
}

model PlanMessage {
  id            String         @id @default(cuid())
  threadId      String
  role          CoachMessageRole
  content       String
  actionType    PlanActionType @default(NONE)
  actionPayload Json?
  createdAt     DateTime       @default(now())
  thread        PlanThread     @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

enum WorkoutParsingStatus {
  DRAFT
  CONFIRMED
}

enum RecommendationStatus {
  DRAFT
  ACCEPTED
  EDITED
  REJECTED
}

enum CoachMessageRole {
  SYSTEM
  USER
  ASSISTANT
}

enum CoachActionType {
  NONE
  REPLACE_EXERCISE
  ADJUST_VOLUME
  ADJUST_REST
  ADJUST_DURATION
  REGENERATE_WORKOUT
}

enum NoteImportSource {
  APPLE_NOTES_SHARE
  MANUAL_PASTE
}

enum TrainingPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TrainingPlanSource {
  AI_GENERATED
  IMPORTED
  MANUAL
}

enum PlanThreadScope {
  PLAN
  WEEK
  DAY
}

enum PlanActionType {
  NONE
  EXPLAIN_DAY
  REPLACE_EXERCISE
  ADJUST_DURATION
  ADJUST_INTENSITY
  ADJUST_VOLUME
  REGENERATE_DAY
  REGENERATE_WEEK
  REGENERATE_PLAN
}

enum DayExecutionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  ADJUSTED
  SKIPPED
}

enum ExerciseExecutionStatus {
  PLANNED
  DONE
  ADJUSTED
  SKIPPED
}

enum NoteImportStatus {
  RECEIVED
  SEGMENTED
  REVIEW_REQUIRED
  COMPLETED
}

enum NoteCandidateDedupeStatus {
  PENDING
  NEW
  POSSIBLE_DUPLICATE
  DUPLICATE
}
