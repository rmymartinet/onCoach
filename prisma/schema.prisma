// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  emailVerified    Boolean          @default(false)
  name             String
  image            String?
  goal             String?
  level            String?
  frequencyPerWeek Int?
  sessionDuration  Int?
  equipment        Json?
  splitPreference  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  accounts         Account[]
  workouts         Workout[]
  recommendations  Recommendation[]
  coachThreads     CoachThread[]
  noteImports      NoteImport[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Workout {
  id             String            @id @default(cuid())
  userId         String
  rawText        String
  cleanedSummary String?
  sessionType    String?
  fatigueNote    String?
  performedAt    DateTime?
  parsingStatus  WorkoutParsingStatus @default(DRAFT)
  parseConfidence Float?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises      WorkoutExercise[]
  recommendations Recommendation[] @relation("RecommendationBaseWorkout")
  matchedCandidates NoteWorkoutCandidate[]

  @@index([userId, createdAt])
}

model WorkoutExercise {
  id             String   @id @default(cuid())
  workoutId      String
  rawLine        String?
  exerciseName   String
  normalizedName String?
  sets           Int?
  reps           Int?
  repMin         Int?
  repMax         Int?
  weight         Float?
  unit           String?
  restSeconds    Int?
  notes          String?
  confidence     Float?
  order          Int
  workout        Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([workoutId, order])
}

model Recommendation {
  id               String    @id @default(cuid())
  userId           String
  basedOnWorkoutId String?
  title            String
  goal             String?
  status           RecommendationStatus @default(DRAFT)
  explanation      String?
  coachSummary     String?
  estimatedDurationMinutes Int?
  workoutJson      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  basedOnWorkout   Workout?  @relation("RecommendationBaseWorkout", fields: [basedOnWorkoutId], references: [id], onDelete: SetNull)
  exercises        RecommendationExercise[]
  thread           CoachThread?

  @@index([userId, createdAt])
  @@index([basedOnWorkoutId])
}

model RecommendationExercise {
  id                String   @id @default(cuid())
  recommendationId  String
  order             Int
  name              String
  normalizedName    String?
  sets              Int
  repMin            Int
  repMax            Int
  restSeconds       Int
  targetRpe         Float?
  rir               Float?
  notes             String?
  warmup            Boolean  @default(false)
  exerciseType      String?
  muscleGroups      Json?
  equipment         Json?
  substitutions     Json?
  recommendation    Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId, order])
}

model CoachThread {
  id               String   @id @default(cuid())
  userId           String
  recommendationId String?  @unique
  title            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendation   Recommendation? @relation(fields: [recommendationId], references: [id], onDelete: SetNull)
  messages         CoachMessage[]

  @@index([userId, updatedAt])
}

model CoachMessage {
  id             String   @id @default(cuid())
  threadId       String
  role           CoachMessageRole
  content        String
  actionType     CoachActionType @default(NONE)
  actionPayload  Json?
  createdAt      DateTime @default(now())
  thread         CoachThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model NoteImport {
  id             String              @id @default(cuid())
  userId         String
  source         NoteImportSource    @default(APPLE_NOTES_SHARE)
  rawText        String
  normalizedText String?
  contentHash    String
  status         NoteImportStatus    @default(RECEIVED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidates     NoteWorkoutCandidate[]

  @@index([userId, createdAt])
  @@index([userId, contentHash])
}

model NoteWorkoutCandidate {
  id               String                    @id @default(cuid())
  noteImportId     String
  title            String?
  rawExcerpt       String
  performedAt      DateTime?
  confidence       Float?
  isMostRecent     Boolean                   @default(false)
  dedupeStatus     NoteCandidateDedupeStatus @default(PENDING)
  dedupeReason     String?
  fingerprint      String?
  parsingStatus    WorkoutParsingStatus      @default(DRAFT)
  matchedWorkoutId String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  noteImport       NoteImport                @relation(fields: [noteImportId], references: [id], onDelete: Cascade)
  matchedWorkout   Workout?                  @relation(fields: [matchedWorkoutId], references: [id], onDelete: SetNull)

  @@index([noteImportId, createdAt])
  @@index([matchedWorkoutId])
}

enum WorkoutParsingStatus {
  DRAFT
  CONFIRMED
}

enum RecommendationStatus {
  DRAFT
  ACCEPTED
  EDITED
  REJECTED
}

enum CoachMessageRole {
  SYSTEM
  USER
  ASSISTANT
}

enum CoachActionType {
  NONE
  REPLACE_EXERCISE
  ADJUST_VOLUME
  ADJUST_REST
  ADJUST_DURATION
  REGENERATE_WORKOUT
}

enum NoteImportSource {
  APPLE_NOTES_SHARE
  MANUAL_PASTE
}

enum NoteImportStatus {
  RECEIVED
  SEGMENTED
  REVIEW_REQUIRED
  COMPLETED
}

enum NoteCandidateDedupeStatus {
  PENDING
  NEW
  POSSIBLE_DUPLICATE
  DUPLICATE
}
